# ----- Railway Environment Variables -----
# These must be set in Railway dashboard

# MySQL connection (provided by Railway MySQL plugin)
MYSQL_URL=jdbc:mysql://<host>:<port>/<database>
MYSQL_USER=<username>
MYSQL_PASSWORD=<password>

# Backend port (Railway sets this automatically)
PORT=8080

# Frontend URL (deployed on Vercel)
FRONTEND_URL=https://<your-frontend>.vercel.app

# JWT secret (generate a strong random string)
JWT_SECRET=<your-jwt-secret>
