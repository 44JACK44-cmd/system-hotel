# ----- Railway Environment Variables -----
# Railway MySQL Plugin auto-generates: MYSQLHOST, MYSQLPORT, MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD
# Do NOT set MYSQL_URL, MYSQL_USER, MYSQL_PASSWORD manually (conflict!)

# Backend port (Railway sets this automatically via PORT)
PORT=8080

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Frontend URL (deployed on Vercel)
FRONTEND_URL=https://system-hotel-fawn.vercel.app

# JWT secret (generate a strong random string)
JWT_SECRET=your-strong-jwt-secret-here
